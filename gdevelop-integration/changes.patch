diff --git a/newIDE/app/src/AiGeneration/AiRequestChat/LocalAiModelSelector.js b/newIDE/app/src/AiGeneration/AiRequestChat/LocalAiModelSelector.js
new file mode 100644
index 0000000..8620bd6
