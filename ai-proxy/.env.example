# Copy to .env and fill in. The proxy reads these at startup.

# Where the proxy listens. The GDevelop IDE must point GDevelopGenerationApi.baseUrl here
# (e.g. http://localhost:4000). See newIDE/app/src/Utils/GDevelopServices/ApiConfigs.js.
PORT=4000

# OpenAI-compatible backend. Examples:
#   Kimi (Moonshot):  https://api.moonshot.ai/v1
#   OpenAI:           https://api.openai.com/v1
#   Ollama (local):   http://localhost:11434/v1
#   vLLM:             http://localhost:8000/v1
PROVIDER_BASE_URL=https://api.moonshot.ai/v1

# API key for the backend above. For local Ollama/vLLM any non-empty string works.
PROVIDER_API_KEY=sk-...

# Model id to request from the backend.
#   Kimi:   kimi-k2-0905-preview   (or moonshot-v1-128k, etc.)
#   OpenAI: gpt-4o / gpt-4.1 / ...
#   Ollama: llama3.1 / qwen2.5 / ...
PROVIDER_MODEL=kimi-k2-0905-preview

# Optional: cap tokens / temperature for chat.
PROVIDER_MAX_TOKENS=4096
PROVIDER_TEMPERATURE=0.7
